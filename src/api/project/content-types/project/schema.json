{
  "kind": "collectionType",
  "collectionName": "project_galleries",
  "info": {
    "singularName": "project",
    "pluralName": "projects",
    "displayName": "Project Gallery"
  },
  "options": { "draftAndPublish": true },
  "attributes": {
    "material": {
      "type": "enumeration",
      "enum": [
        "LVT & Vinyl Plank",
        "Carpet & Carpet Tile",
        "Ceramic & Tile",
        "Backsplash & Wall Tile",
        "Shower & Wet Areas",
        "Hardwood",
        "Epoxy Flooring",
        "Other"
      ],
      "required": true
    },
    "customMaterial": {
      "type": "string",
      "description": "Only used when Material = Other. Must follow existing naming conventions."
    },
    "featured": {
      "type": "boolean",
      "default": false
    },
    "materialId": { "type": "string", "required": true },
    "images": { "type": "media", "multiple": true, "allowedTypes": ["images"] }
  }
}