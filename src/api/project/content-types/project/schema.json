{
  "kind": "collectionType",
  "collectionName": "project_galleries",
  "info": {
    "singularName": "project",
    "pluralName": "projects",
    "displayName": "Project Gallery"
  },
  "options": { "draftAndPublish": true },
  "attributes": {
    "material": {
      "type": "enumeration",
      "enum": [
        "LVT & Vinyl Plank",
        "Carpet & Carpet Tile",
        "Ceramic & Tile",
        "Backsplash & Wall Tile",
        "Shower & Wet Areas",
        "Hardwood",
        "Epoxy Flooring",
        "Other"
      ],
      "required": true
    },
    "customMaterial": {
      "type": "string",
      "description": "Only used when Material = Other. Must follow existing naming conventions."
    },
    "materialId": { "type": "string" },
    "images": { "type": "media", "multiple": true, "allowedTypes": ["images"] },
    "carouselImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"],
      "description": "Imagen representativa de este material para el carousel principal"
    }
  }
}