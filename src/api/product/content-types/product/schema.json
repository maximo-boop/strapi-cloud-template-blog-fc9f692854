	},
	"attributes": {
		"title": {
			"type": "string",
			"required": true
		},
		"category": {
			"type": "enumeration",
			"enum": [
				"Luxury Vinyl Plank",
				"Laminate",
				"Ceramic Tile",
				"Porcelain Tile",
				"Underlayment",
				"Epoxy Floor Coatings",
				"Resin Pigments",
				"Floor Coatings",
				"Polyaspartic & Urethane"
			],
			"required": true
		},
		"size": {
			"type": "string"
		},
		"price_sqf": {
			"type": "decimal"
		},
		"price_unit": {
			"type": "decimal"
		},
		"price_box": {
			"type": "decimal"
		},
		"image": {
			"type": "media",
